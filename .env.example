# Copy this file to .env only on the VPS or local machine that runs the bot.
# Do not commit .env. Do not put withdrawal-enabled keys here.

EXCHANGE_NAME=binance

# Exchange API keys are optional for dry-run startup and must never have withdrawal permission.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Keep dry-run enabled. docker-compose.yml also forces this to true by default.
FREQTRADE__DRY_RUN=true

# Optional Telegram alerts. The bot runs without these.
FREQTRADE__TELEGRAM__ENABLED=false
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# Local-only Web UI/API credentials. Replace before using on a VPS, even behind SSH tunnel.
BTC_FREQTRADE__API_SERVER__USERNAME=freqtrader_btc
BTC_FREQTRADE__API_SERVER__PASSWORD=change-me-btc-local-only
BTC_FREQTRADE__API_SERVER__JWT_SECRET_KEY=change-me-btc-jwt-secret-local-only
BTC_FREQTRADE__API_SERVER__WS_TOKEN=change-me-btc-ws-local-only

ETH_FREQTRADE__API_SERVER__USERNAME=freqtrader_eth
ETH_FREQTRADE__API_SERVER__PASSWORD=change-me-eth-local-only
ETH_FREQTRADE__API_SERVER__JWT_SECRET_KEY=change-me-eth-jwt-secret-local-only
ETH_FREQTRADE__API_SERVER__WS_TOKEN=change-me-eth-ws-local-only

SOL_FREQTRADE__API_SERVER__USERNAME=freqtrader_sol
SOL_FREQTRADE__API_SERVER__PASSWORD=change-me-sol-local-only
SOL_FREQTRADE__API_SERVER__JWT_SECRET_KEY=change-me-sol-jwt-secret-local-only
SOL_FREQTRADE__API_SERVER__WS_TOKEN=change-me-sol-ws-local-only

# XAUT remains validation-gated. Do not enable the xaut-validated compose profile
# until scripts/check_xaut_markets.sh confirms a futures market.
XAUT_EXCHANGE_NAME=binance
XAUT_FREQTRADE__API_SERVER__USERNAME=freqtrader_xaut
XAUT_FREQTRADE__API_SERVER__PASSWORD=change-me-xaut-local-only
XAUT_FREQTRADE__API_SERVER__JWT_SECRET_KEY=change-me-xaut-jwt-secret-local-only
XAUT_FREQTRADE__API_SERVER__WS_TOKEN=change-me-xaut-ws-local-only

KILL_SWITCH_PATH=runtime/KILL_SWITCH

# Read-only unified dashboard.
DASHBOARD_PORT=8090
DASHBOARD_REQUEST_TIMEOUT=3
DASHBOARD_XAUT_VALIDATION_TTL=300
